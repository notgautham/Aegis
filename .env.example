# Copy this file to `.env`.
# Default mode is fully local and deterministic.
# No cloud API keys are required for local development.

# Database & Vector DB
DATABASE_URL=postgresql+asyncpg://aegis:aegis@postgres:5432/aegis
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_NAME=aegis_nist_docs
DOCS_SOURCE_DIR=docs/nist

# Application
PROJECT_NAME=Aegis
API_V1_STR=/api/v1
SECRET_KEY=change-me-in-production
SKIP_ENUMERATION=true

# Intelligence mode
EMBEDDING_PROVIDER_MODE=local
LLM_PROVIDER_MODE=local
RAG_TOP_K=5
LLM_TIMEOUT_SECONDS=20.0
EMBEDDING_TIMEOUT_SECONDS=20.0

# Certificate issuer defaults
CERT_ISSUER_COMMON_NAME=Aegis Compliance CA
CERT_ISSUER_ORGANIZATION=Aegis
CERT_ISSUER_ORG_UNIT=Quantum Compliance
CERT_RUNTIME_DIR=.aegis-runtime/certs

# Optional cloud providers (only needed if you intentionally enable cloud mode)
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# GROQ_API_KEY=
# GROQ_MODEL=qwen/qwen3-32b
#
# JINA_BASE_URL=https://api.jina.ai/v1
# JINA_API_KEY=
# JINA_EMBEDDING_MODEL=jina-embeddings-v3
#
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemma-3-27b-it
# OPENROUTER_EMBEDDING_MODEL=text-embedding-3-small
#
# COHERE_BASE_URL=https://api.cohere.com/v2
# COHERE_API_KEY=
# COHERE_EMBEDDING_MODEL=embed-english-v3.0
